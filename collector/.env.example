# Conexão com o PostgreSQL (container Docker)
DB_URL=postgresql://adlogs:adlogs@localhost:5434/adlogs

# URL da API (para heartbeat e busca de configuração)
API_URL=http://localhost:3001

# Intervalo de coleta em segundos (padrão: 30)
POLL_INTERVAL=30

# Versão do coletor
COLLECTOR_VERSION=1.0.0

# Nome do serviço Windows
SERVICE_NAME=ADLogsCollector
SERVICE_DISPLAY_NAME=ADLogs - Coletor de Auditoria
SERVICE_DESCRIPTION=Coleta eventos de login e acesso a arquivos do Windows Event Log e persiste no PostgreSQL.
