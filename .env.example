# === Ambiente ===
APP_ENV=dev
NODE_ENV=development

# === Banco de Dados ===
DATABASE_URL="postgresql://adlogs:adlogs@localhost:5434/adlogs?schema=public"

# === JWT ===
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria-em-producao"
JWT_SECRET_OLD=""
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# === API ===
PORT=3001
ALLOWED_ORIGINS="http://localhost:3000"

# === Frontend ===
NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_API_URL="http://localhost:3001"

# === Collector (usado pelo coletor Python) ===
# Copie este bloco para collector/.env
COLLECTOR_DB_URL="postgresql://adlogs:adlogs@localhost:5434/adlogs"
COLLECTOR_POLL_INTERVAL_SECONDS=30
COLLECTOR_API_URL="http://localhost:3001"
