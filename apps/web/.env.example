# URL pública da API — obrigatória em produção.
# Substitua pelo IP ou domínio real do servidor.
# Esta variável é incorporada no build do Next.js (NEXT_PUBLIC_*),
# portanto o `next build` DEVE ser executado após criar este arquivo.
NEXT_PUBLIC_API_URL=http://SEU_IP_OU_DOMINIO:3001

NEXT_PUBLIC_APP_ENV=production
